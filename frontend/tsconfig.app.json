{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* SAFE SETTINGS */
    "moduleResolution": "Bundler",
    "noEmit": false,
    "jsx": "react-jsx",

    /* Linting */
    
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}