{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "types": ["node"],
    "skipLibCheck": true,

    /* SAFE NODE CONFIG */
    "moduleResolution": "Bundler",
    "noEmit": true,

    /* Linting */
   
    "noFallthroughCasesInSwitch": true
  },
  "include": ["vite.config.ts"]
}